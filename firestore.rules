rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow users to read/write their own user document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow authenticated users to read rewards and write spin history
    match /rewards/{rewardId} {
      allow read: if request.auth != null;
    }
    
    match /spin_history/{spinId} {
      allow write: if request.auth != null;
    }

    // Default: Allow read/write for authenticated users during initial setup
    // You can tighten this later before publishing
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
